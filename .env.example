# Base URL for the chatbot demo under test
BASE_URL=https://chatbot.ai-sdk.dev/demo

# Timeout for page navigation (milliseconds)
NAVIGATION_TIMEOUT=30000

# Timeout for individual actions like clicks and typing (milliseconds)
ACTION_TIMEOUT=10000

# Timeout for waiting for chatbot response to complete (milliseconds)
RESPONSE_TIMEOUT=30000

# Delay between test scenarios to mitigate rate limiting (milliseconds)
INTER_SCENARIO_DELAY=2000

# Maximum number of retry attempts for failed assertions
RETRY_ATTEMPTS=3

# Multiplier for exponential backoff between retries
BACKOFF_MULTIPLIER=2

# Minimum similarity score (0-1) for semantic assertion to pass
SEMANTIC_THRESHOLD=0.7
